{
  "version": 2,
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/sweet-fantasy-vlas-main/index.html"
    },
    {
      "source": "/app.js",
      "destination": "/frontend/sweet-fantasy-vlas-main/app.js"
    },
    {
      "source": "/images/:path*",
      "destination": "/frontend/sweet-fantasy-vlas-main/images/:path*"
    },
    {
      "source": "/robots.txt",
      "destination": "/frontend/sweet-fantasy-vlas-main/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/frontend/sweet-fantasy-vlas-main/sitemap.xml"
    }
  ]
}
